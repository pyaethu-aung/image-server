#!/usr/bin/env bash
# pre-push: enforce lint, unit-test coverage, and OpenAPI spec gates
# before every push

set -euo pipefail

# ---------------------------------------------------------------------------
# 1. Lint gate (golangci-lint, config in .golangci.yml)
# ---------------------------------------------------------------------------

echo "🔍 pre-push: running golangci-lint..."

if ! make -s lint; then
  echo ""
  echo "❌ Lint gate failed: fix the issues above before pushing."
  exit 1
fi

echo "✅ Lint gate passed"

# ---------------------------------------------------------------------------
# 2. Coverage gate (90% minimum, per layer and overall)
#    Logic lives in scripts/coverage-gate.sh, shared with CI.
# ---------------------------------------------------------------------------

echo ""
echo "🔍 pre-push: checking test coverage..."

./scripts/coverage-gate.sh

# ---------------------------------------------------------------------------
# 3. API spec gate — every endpoint must satisfy docs/openapi/image-server.yaml
# ---------------------------------------------------------------------------

echo ""
echo "🔍 pre-push: running API spec tests..."

if ! make -s test-api; then
  echo ""
  echo "❌ API spec gate failed: endpoints violate docs/openapi/image-server.yaml."
  exit 1
fi

echo ""
echo "✅ All gates passed, safe to push."
