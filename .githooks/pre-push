#!/usr/bin/env bash
# pre-push: enforce lint, unit-test coverage, OpenAPI spec, and full-stack
# e2e gates before every push (the e2e gate is local-only; see gate 4 below)

set -euo pipefail

# ---------------------------------------------------------------------------
# 1. Lint gate (golangci-lint, config in .golangci.yml)
# ---------------------------------------------------------------------------

echo "🔍 pre-push: running golangci-lint..."

if ! make -s lint; then
  echo ""
  echo "❌ Lint gate failed: fix the issues above before pushing."
  exit 1
fi

echo "✅ Lint gate passed"

# ---------------------------------------------------------------------------
# 2. Coverage gate (90% minimum, per layer and overall)
#    Logic lives in scripts/coverage-gate.sh, shared with CI.
# ---------------------------------------------------------------------------

echo ""
echo "🔍 pre-push: checking test coverage..."

./scripts/coverage-gate.sh

# ---------------------------------------------------------------------------
# 3. API spec gate — every endpoint must satisfy docs/openapi/image-server.yaml
# ---------------------------------------------------------------------------

echo ""
echo "🔍 pre-push: running API spec tests..."

if ! make -s test-api; then
  echo ""
  echo "❌ API spec gate failed: endpoints violate docs/openapi/image-server.yaml."
  exit 1
fi

echo "✅ API spec gate passed"

# ---------------------------------------------------------------------------
# 4. Full-stack e2e gate — real Docker container. LOCAL-ONLY: unlike gates
#    1-3, CI does NOT re-run this. A bypassed hook (--no-verify) or an
#    unconfigured clone has zero backstop for this specific gate.
# ---------------------------------------------------------------------------

echo ""
echo "🔍 pre-push: running full-stack e2e tests against the real container (local-only, no CI backstop)..."

if ! make -s test-e2e; then
  echo ""
  echo "❌ e2e gate failed: the real server container is broken end-to-end."
  exit 1
fi

echo "✅ e2e gate passed"

echo ""
echo "✅ All gates passed, safe to push."
