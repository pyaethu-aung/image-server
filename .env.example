# Copy to .env and adjust. Never commit .env or real credentials.
API_KEY=dev-key-change-me
LISTEN_ADDR=:8080
# Host ports 5434/6380 avoid clashes with other local stacks on 5432/6379
# (see POSTGRES_HOST_PORT / REDIS_HOST_PORT in docker-compose.yml)
DATABASE_URL=postgres://postgres:postgres@localhost:5434/imageserver?sslmode=disable
REDIS_ADDR=localhost:6380
STORAGE_PATH=./data/images
MAX_UPLOAD_BYTES=10485760
MAX_PIXELS=50000000
RATE_LIMIT_PER_MIN=120
# Cache-Control max-age (seconds) for served image bytes; default 1 year.
CACHE_CONTROL_MAX_AGE=31536000
